# Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Application ID (from Discord Developer Portal)
DISCORD_CLIENT_ID=your_application_id_here

# Anthropic API Key (from console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Channel ID where Claude listens (right-click channel > Copy Channel ID)
CLAUDE_CHANNEL_ID=your_channel_id_here

# Claude model to use
CLAUDE_MODEL=claude-sonnet-4-6

# Max conversation history per user (number of message pairs kept in memory)
MAX_HISTORY=20

# System prompt for Claude
SYSTEM_PROMPT=Tu es Claude, un assistant IA d'Anthropic. Tu es intégré dans un serveur Discord en tant qu'associé digital. Tu réponds de manière concise, utile et professionnelle. Tu peux aider avec le code, la stratégie, l'analyse et la création de contenu. Réponds en français sauf si on te parle dans une autre langue.
